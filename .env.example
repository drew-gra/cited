# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres (provisioned via Vercel Marketplace).
# Use the pooled connection string for the runtime.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Inngest. Get from https://app.inngest.com after connecting the project.
# For local dev, set INNGEST_DEV=1 and leave the keys empty — the SDK will
# talk to the local Inngest dev server (npx inngest-cli@latest dev) instead
# of api.inngest.com.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Crawler identity. Public URL on breadandlaw.com that explains the bot.
CITED_CONTACT_URL=https://breadandlaw.com/cited
CITED_USER_AGENT="AICitabilityBot/1.0 (+https://breadandlaw.com/cited)"
